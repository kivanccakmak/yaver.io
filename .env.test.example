# Yaver Test Suite — Credential Template
# ═══════════════════════════════════════════════════════════════════
# Copy to .env.test (gitignored) or place at ../talos/.env.test
# For CI, set these as GitHub Actions secrets instead.
#
# Which tests need which variables:
#   --unit, --lan, --relay   → no credentials needed (uses Convex dev backend)
#   --relay-docker           → REMOTE_SERVER_IP + SSH key
#   --relay-binary           → REMOTE_SERVER_IP + SSH key
#   --tailscale              → REMOTE_SERVER_IP + SSH key (+ tailscale on both machines)
#   --cloudflare             → CF_TUNNEL_URL + CF_ACCESS_CLIENT_ID + CF_ACCESS_CLIENT_SECRET
# ═══════════════════════════════════════════════════════════════════

# ── Convex Backend ──────────────────────────────────────────────────
# Public Convex endpoint for test account signup/validation.
# Default works out of the box — only override if you have your own Convex instance.
# CONVEX_SITE_URL=https://shocking-echidna-394.eu-west-1.convex.site

# ── Remote Server (Hetzner VPS or any Linux server with SSH) ──────
# Used by: --relay-docker, --relay-binary, --tailscale
# The test suite SSHs into this server to deploy relay/agent binaries,
# run them, test connectivity, then tear everything down.
REMOTE_SERVER_IP=
REMOTE_SERVER_USER=root
REMOTE_SERVER_SSH_KEY=~/.ssh/id_rsa

# ── Cloudflare Tunnel ──────────────────────────────────────────────
# Used by: --cloudflare
# The tunnel URL should point to a running agent behind Cloudflare Access.
# Service tokens are created in Cloudflare Zero Trust → Access → Service Auth.
CF_TUNNEL_URL=
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
